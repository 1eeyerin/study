{
  "compilerOptions": {
    // ECMAScript 5(ES5) 버전을 대상으로 컴파일합니다.
    "target": "es5",
    // CommonJS 모듈 시스템을 사용하여 모듈을 생성합니다.
    "module": "commonjs",
    // 다양한 라이브러리와 ECMAScript 버전을 포함하여 컴파일할 때 사용할 라이브러리와 기능을 지정합니다.
    "lib": ["dom", "ES2015", "ES2016", "ES2017", "ES2018", "ES2019", "ES2020"],
    // JavaScript 파일도 허용하여 컴파일할 수 있습니다.
    "allowJs": true,
    // JSX 문법을 사용하며, React 애플리케이션을 개발하는 경우에 유용합니다.
    "jsx": "react-jsx",
    // 소스 맵을 생성하여 디버깅을 지원합니다.
    "sourceMap": true,
    // 컴파일된 파일의 출력 디렉토리를 지정합니다.
    "outDir": "./dist",
    // 각 파일을 독립적으로 컴파일합니다.
    "isolatedModules": true,
    // 엄격한 타입 체크 및 엄격한 검사 옵션을 활성화합니다.
    "strict": true,
    // 모듈 해결 방법을 Node.js 스타일로 설정합니다.
    "moduleResolution": "node",
    // 모듈 해결 시 기준이 되는 기본 경로를 설정합니다.
    "baseUrl": "./",
    // 모듈 경로 별칭을 설정하여 더 짧은 모듈 경로를 사용할 수 있습니다.
    "paths": {
      "@components/*": ["components/*"],
      "@pages/*": ["pages/*"]
    },
    // import module from 'module' 형태의 구문을 허용합니다.
    "allowSyntheticDefaultImports": true,
    // CommonJS와 ES 모듈 간 상호 운용성을 개선합니다.
    "esModuleInterop": true,
    // 파일 이름의 일관된 대소문자 사용을 강제합니다.
    "forceConsistentCasingInFileNames": true,
    // 라이브러리 검사를 생략합니다 (일부 성능 향상에 도움이 될 수 있음).
    "skipLibCheck": true
  }
}
